# Copy to `.env` and fill in the blanks before running the Django server.
# Never commit the real values.
#
# Defaults below are tuned for local development (DEBUG on, plain HTTP).
# For production, flip DJANGO_DEBUG to False, set DJANGO_ALLOWED_HOSTS to
# your real hostname(s), and supply both secrets.

# Required when DJANGO_DEBUG=False; auto-generated each start when DEBUG=True.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# True for local development; False for production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames the server will accept.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Hard cap on uploaded reading-history files (bytes). Default 5 MB.
MAX_UPLOAD_BYTES=5242880

# Force redirects from http -> https. Has no effect when DJANGO_DEBUG=True.
# Set to False if a reverse proxy already terminates TLS and rewrites.
DJANGO_SECURE_SSL_REDIRECT=True

# HSTS max-age. 1 year by default; lower while you're still validating TLS setup.
DJANGO_HSTS_SECONDS=31536000

# HMAC shared secret for client request signing. Must match the
# REQUEST_SIGNING_SECRET baked into the Android client at build time.
# Empty + DEBUG=True bypasses signature checks for local dev. In production
# this MUST be set, or the server rejects every request with 403.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REQUEST_SIGNING_SECRET=
